# Database (used by docker compose)
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=linksburg
POSTGRES_PORT=5433

# Backend security and auth
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=https://app.example.com

# Signup guardrails
SIGNUP_ALLOWED=false
SIGNUP_BLOCK_MESSAGE=Cant create new account for the moment please reach us via whatsapp message

# Admin bootstrap account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
ADMIN_FULLNAME=flipconnects Admin

# Frontend API base (works with same-domain /api proxy)
VITE_API_URL=/api
